{
  "name": "lucky50-investment",
  "version": "1.0.0",
  "type": "module",
  "description": "農民曆智慧投資 - 0050 ETF 投資建議系統",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:tsc": "vue-tsc --noEmit && vite build",
    "build:analyze": "vite build --mode analyze",
    "ai-workflow": "bash scripts/ai-bridge.sh",
    "ai-workflow:status": "bash scripts/ai-workflow-status.sh",
    "ai-workflow:switch": "bash scripts/ai-workflow-switch.sh",
    "ai-workflow:kill": "bash scripts/ai-workflow-kill.sh",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@tweenjs/tween.js": "^25.0.0",
    "@vuepic/vue-datepicker": "^11.0.2",
    "axios": "^1.6.0",
    "chart.js": "^4.4.0",
    "chinese-s2t": "^1.0.0",
    "date-fns": "^2.30.0",
    "lunar-javascript": "^1.6.12",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "three": "^0.158.0",
    "vue": "^3.5.39",
    "vue-chartjs": "^5.3.4",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.8.10",
    "@types/three": "^0.158.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.3.3",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.16",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.3.5",
    "terser": "^5.49.0",
    "typescript": "^5.9.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
