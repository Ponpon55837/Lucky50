{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "initialization": {
        "preferences": {
          "importModuleSpecifierPreference": "non-relative",
          "includePackageJsonAutoImports": "on",
          "autoImportFileExcludePatterns": ["node_modules/**"]
        }
      }
    }
  },
  "instructions": ["AGENTS.md", "ARCHITECTURE.md"],
  "formatter": {
    "prettier": {}
  },
  "plugin": ["opencode-morph-fast-apply", "opencode-dynamic-context-pruning"],
  "mcp": {
    "tmux-bridge": {
      "type": "local",
      "command": ["npx", "-y", "tmux-bridge-mcp"],
      "enabled": true
    }
  }
}
