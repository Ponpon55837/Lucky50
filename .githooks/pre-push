#!/bin/bash

# Lucky50 專案 - Pre-push Hook
# 推送前執行 TypeScript 類型檢查，確保程式碼品質

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo ""
echo -e "${BLUE}🔍 執行推送前類型檢查...${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# 執行 TypeScript 類型檢查
echo -e "${YELLOW}執行 vue-tsc --noEmit ...${NC}"
START_TIME=$(date +%s)

if npx vue-tsc --noEmit 2>&1; then
  END_TIME=$(date +%s)
  DURATION=$((END_TIME - START_TIME))
  echo ""
  echo -e "${GREEN}✅ 類型檢查通過 (${DURATION}s)${NC}"
  echo ""
  exit 0
else
  END_TIME=$(date +%s)
  DURATION=$((END_TIME - START_TIME))
  echo ""
  echo -e "${RED}❌ 類型檢查失敗 (${DURATION}s)${NC}"
  echo ""
  echo -e "${YELLOW}請修正上述 TypeScript 錯誤後再推送。${NC}"
  echo ""
  echo -e "${YELLOW}💡 如需跳過檢查：git push --no-verify${NC}"
  echo ""
  exit 1
fi
